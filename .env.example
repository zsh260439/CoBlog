MONGODB_URI=mongodb://127.0.0.1:27017/coblog
PORT=3000

JWT_SECRET=replace_with_your_jwt_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_with_your_jwt_refresh_secret

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=replace_with_your_admin_password

DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash

# Frontend dev-only variables can be placed in .env.development.local
# Example:
# VITE_API_BASE_URL=http://localhost:3000
